  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "targets": [
        {
          "expr": "sum(up{job=~\"proxbridge-node-disk|proxbridge-smartctl\"})",
          "legendFormat": "up",
          "refId": "A"
        }
      ],
      "title": "Exporters Up",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(node_scrape_collector_success{job=\"proxbridge-node-disk\"})",
          "legendFormat": "ok",
          "refId": "A"
        }
      ],
      "title": "Node Collectors OK",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "smartctl_device_smart_status{job=\"proxbridge-smartctl\"}",
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "SMART Status by Device",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "smartctl_device_temperature{job=\"proxbridge-smartctl\", temperature_type=\"current\"}",
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "Drive Temperatures",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "targets": [
        {
          "expr": "smartctl_device_percentage_used{job=\"proxbridge-smartctl\"}",
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "SSD Wear",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "targets": [
        {
          "expr": "smartctl_device_power_on_seconds{job=\"proxbridge-smartctl\"} / 3600",
          "legendFormat": "{{ device }}",
          "refId": "A"
        }
      ],
      "title": "Power-On Hours",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 7,
      "targets": [
        {
          "expr": "smartctl_device_bytes_read{job=\"proxbridge-smartctl\"}",
          "legendFormat": "{{ device }} read",
          "refId": "A"
        },
        {
          "expr": "smartctl_device_bytes_written{job=\"proxbridge-smartctl\"}",
          "legendFormat": "{{ device }} written",
          "refId": "B"
        }
      ],
      "title": "Lifetime Bytes Read / Written",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"proxbridge-node-disk\", device!~\"loop|ram.*\"}[5m])",
          "legendFormat": "{{ device }} read",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"proxbridge-node-disk\", device!~\"loop|ram.*\"}[5m])",
          "legendFormat": "{{ device }} written",
          "refId": "B"
        }
      ],
      "title": "Disk Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 9,
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{job=\"proxbridge-node-disk\", fstype!~\"tmpfs|devtmpfs|fuse.*|overlay|squashfs\", mountpoint!~\"/run.*|/tmp|/var/lib/lxcfs\"} / node_filesystem_size_bytes{job=\"proxbridge-node-disk\", fstype!~\"tmpfs|devtmpfs|fuse.*|overlay|squashfs\", mountpoint!~\"/run.*|/tmp|/var/lib/lxcfs\"})",
          "legendFormat": "{{ mountpoint }}",
          "refId": "A"
        }
      ],
      "title": "Filesystem Usage",
      "type": "timeseries"
    }
  ],
