{% for key in lookup('pipe', 'env | cut -d= -f1 | grep ^OPENCLAW_ || true').splitlines() %}
{% if key != 'OPENCLAW_CLUSTER_TOKEN' and not key.startswith('OPENCLAW_TELEGRAM_') %}
{{ key }}="{{ lookup('env', key) }}"
{% endif %}
{% endfor %}
OPENCLAW_CLUSTER_TOKEN="{{ openclaw_cluster_token }}"
OPENROUTER_API_KEY={{ lookup('env', 'OPENROUTER_API_KEY') }}
NVIDIA_API_KEY={{ lookup('env', 'NVIDIA_API_KEY') }}
GEMINI_API_KEY={{ lookup('env', 'GEMINI_API_KEY') }}
GROQ_API_KEY={{ lookup('env', 'GROQ_API_KEY')}}
NODE_COMPILE_CACHE=/var/tmp/openclaw-compile-cache
OPENCLAW_NO_RESPAWN=1
KUBECONFIG="{{ openclaw_support_home }}/.kube/config"
ALPACA_SECRET_KEY={{ lookup('env', 'ALPACA_SECRET_KEY') }}
ALPACA_API_KEY={{ lookup('env', 'ALPACA_API_KEY') }}
EXECUTION_MODE=paper
AUTONOMOUS_EXECUTION_ENABLED=true
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_FEED=iex
PAPER_STRATEGY_CAPITAL_USD=100000
MOUNTAINVALUE_ORDER_CLIENT_PREFIX=mvalue-paper-
MOUNTAINVALUE_LEDGER_PATH=/root/.openclaw/mountainvalue/trading.sqlite
MOUNTAINVALUE_TIMEZONE=America/New_York
OPENCLAW_EQUITY_DISCORD_FORUM_CHANNEL_ID={{ lookup('env', 'OPENCLAW_EQUITY_DISCORD_FORUM_CHANNEL_ID') | default('1504282224789295134', true) }}
