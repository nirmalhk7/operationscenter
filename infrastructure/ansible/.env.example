# Copy to infrastructure/ansible/.env and fill local values.
# This file is intentionally non-secret.

# Proxmox host/bootstrap
PROXMOX_HOST=10.0.0.10
PROXMOX_WIFI_PSK=
PROXMOX_OIDC_CLIENT_SECRET=
HOMEPAGE_PROXMOX_PASSWORD=
TAILSCALE_AUTHKEY=
TAILSCALE_ARGS=--ssh

# Nginx / certificates
CERTBOT_EMAIL=
CLOUDFLARE_API_TOKEN=

# Shared Docker databases
CLICKHOUSE_PASSWORD=
MARIADB_ROOT_PASSWORD=
MARIADB_RW_PASSWORD=
VECTORCHORD_PG_PASSWORD=
VECTORCHORD_RW_PASSWORD=
MONGODB_ROOT_PASSWORD=

# OpenClaw runtime
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENCLAW_GITHUB_TOKEN=
OPENCLAW_TODOIST_API_KEY=
OPENCLAW_ALPHAVANTAGE_API_KEY=
OPENCLAW_EDGAR_USER_AGENT=
OPENCLAW_DISCORD_BOT_TOKEN_MAIN=
OPENCLAW_DISCORD_BOT_TOKEN_RAHUL=
OPENCLAW_DISCORD_BOT_TOKEN_VICTOR=
OPENCLAW_EQUITY_DISCORD_FORUM_CHANNEL_ID=1504282224789295134

# OpenClaw trading integrations
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Optional fallback when vm-k8mgd cannot be queried during OpenClaw deploy.
OPENCLAW_CLUSTER_TOKEN=
OPENCLAW_CLUSTER_CA=
OPENCLAW_CLIENT_CERT=
OPENCLAW_CLIENT_KEY=
